{
	"name": "@bataitools/bat-cli",
	"version": "1.3.0",
	"type": "module",
	"description": "BAT AI Tools — Scoped CLI to submit and publish multi-language AI Agents & Skills to the AI Directory Platform",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bataitools/bat-cli.git"
	},
	"bin": {
		"bat-cli": "dist/cli.js"
	},
	"main": "./dist/cli.js",
	"files": [
		"dist",
		"examples"
	],
	"scripts": {
		"build": "bun build ./src/cli.ts --outdir ./dist --target node --external playwright",
		"dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 bun run src/cli.ts --dev",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"release": "release-it",
		"prepare:pkg": "bun run scripts/prepare-package.ts",
		"build:pkg": "bun run build && bun run prepare:pkg",
		"prepare": "husky"
	},
	"dependencies": {
		"decode-ico": "^0.4.1",
		"playwright": "^1.49.1",
		"sharp": "^0.34.5"
	},
	"devDependencies": {
		"@release-it/conventional-changelog": "^11.0.1",
		"@types/node": "^22.10.0",
		"bun-types": "^1.3.14",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"prettier": "^3.8.4",
		"release-it": "^20.2.0",
		"typescript": "^5.7.2"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"lint-staged": {
		"*.(ts|tsx|js|jsx|json|md)": "prettier --write"
	}
}
