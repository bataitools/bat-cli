{
  "name": "@bataitools/bat-cli",
  "version": "1.1.0",
  "type": "module",
  "description": "BAT AI Tools — Agent/Skill CLI for multi-language product submission",
  "bin": {
    "bat-cli": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "skills",
    "prompts",
    "examples"
  ],
  "scripts": {
    "build": "bun build ./src/cli.ts --outdir ./dist --target node --external playwright",
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "release": "release-it",
    "publish:npm": "bun run scripts/publish-npm.ts",
    "publish:npm:dry-run": "bun run scripts/publish-npm.ts --dry-run"
  },
  "dependencies": {
    "decode-ico": "^0.4.1",
    "playwright": "^1.49.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/node": "^22.10.0",
    "bun-types": "^1.3.14",
    "release-it": "^20.2.0",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
